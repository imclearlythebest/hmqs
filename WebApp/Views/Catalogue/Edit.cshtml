@{
  ViewData["Title"] = "Edit Metadata";
}

@section Styles {
  <style>
    .metadata-editor {
      max-width: 840px;
      margin: 0 auto 6rem auto;
    }
  </style>
}

<article class="metadata-editor hmqs-panel p-4"
         data-file-name="@ViewData["FileName"]"
         x-data="window.hmqsPages.metadataEditorFromElement($el)"
         x-init="init()">
  <header class="mb-3">
    <h4 class="mb-1">Edit Metadata</h4>
    <p class="text-body-secondary small mb-0">File: @ViewData["FileName"]</p>
  </header>

  <div class="alert alert-danger" role="alert" x-show="error" x-text="error"></div>
  <div class="alert alert-success" role="alert" x-show="success" x-text="success"></div>

  <form x-on:submit.prevent="save()" class="row g-3">
    <div class="col-md-4">
      <label for="itunesTrackId" class="form-label">iTunes Track ID</label>
      <input id="itunesTrackId" class="form-control" type="number" x-model.number="form.itunesTrackId" min="0" />
    </div>

    <div class="col-md-8">
      <label for="trackTitle" class="form-label">Track Title</label>
      <input id="trackTitle" class="form-control" type="text" x-model="form.trackTitle" />
    </div>

    <div class="col-md-4">
      <label for="itunesArtistId" class="form-label">iTunes Artist ID</label>
      <input id="itunesArtistId" class="form-control" type="number" x-model.number="form.itunesArtistId" min="0" />
    </div>

    <div class="col-md-8">
      <label for="artist" class="form-label">Artist</label>
      <input id="artist" class="form-control" type="text" x-model="form.artist" />
    </div>

    <div class="col-md-4">
      <label for="itunesCollectionId" class="form-label">iTunes Collection ID</label>
      <input id="itunesCollectionId" class="form-control" type="number" x-model.number="form.itunesCollectionId" min="0" />
    </div>

    <div class="col-md-8">
      <label for="album" class="form-label">Album Name</label>
      <input id="album" class="form-control" type="text" x-model="form.album" />
    </div>

    <div class="col-md-6">
      <label for="genre" class="form-label">Genre</label>
      <input id="genre" class="form-control" type="text" x-model="form.genre" />
    </div>

    <div class="col-md-2">
      <label for="year" class="form-label">Year</label>
      <input id="year" class="form-control" type="number" x-model.number="form.year" min="0" />
    </div>

    <div class="col-md-6">
      <label for="imageUrl" class="form-label">Image Url</label>
      <input id="imageUrl" class="form-control" type="url" x-model="form.imageUrl" />
    </div>

    <div class="col-12 d-flex gap-2">
      <button type="button"
              class="btn btn-sm btn-outline-primary"
              :disabled="autoFilling || saving"
              x-on:click="autoFillFromItunes()"
              x-text="autoFilling ? 'Searching...' : 'Find iTunes Matches'"></button>
      <button type="submit" class="btn btn-sm btn-primary" :disabled="saving" x-text="saving ? 'Saving...' : 'Save'"></button>
      <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">Back</a>
    </div>

    <div class="col-12" x-show="candidates.length > 0">
      <div class="border rounded p-3 bg-body-tertiary">
        <p class="small text-body-secondary mb-2">Pick the best match:</p>
        <template x-for="(candidate, index) in candidates" :key="candidate.metadata.itunesTrackId || index">
          <div class="d-flex align-items-start justify-content-between gap-3 border rounded p-2 mb-2 bg-body">
            <div class="d-flex gap-2 align-items-start">
              <img x-show="candidate.imageUrl" :src="candidate.imageUrl" alt="Artwork" class="rounded" style="width:48px;height:48px;object-fit:cover;" />
              <div>
                <div class="fw-semibold" x-text="candidate.trackTitle || 'Unknown Title'"></div>
                <div class="small text-body-secondary" x-text="candidate.artist || 'Unknown Artist'"></div>
                <div class="small text-body-secondary" x-text="candidate.album || 'Unknown Album'"></div>
              </div>
            </div>
            <button type="button" class="btn btn-sm btn-outline-success" x-on:click="applyCandidate(candidate)">Use This</button>
          </div>
        </template>
      </div>
    </div>
  </form>
</article>

@section Scripts {
}
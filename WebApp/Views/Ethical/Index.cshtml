@model WebApp.Models.Dtos.EthicalCalculatorViewDto

@{
    ViewData["Title"] = "Ethical Calculator";
}

<div class="hmqs-panel p-3 p-lg-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <h5 class="m-0">Ethical Calculator</h5>
        <span class="small text-muted">Artist support suggestions from your history</span>
    </div>

    @if (TempData["EthicalMessage"] is string message && !string.IsNullOrWhiteSpace(message))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @message
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="get" asp-action="Index" asp-controller="Ethical" class="row g-2 align-items-end mb-4">
        <div class="col-sm-6 col-md-4 col-lg-3">
            <label class="form-label small fw-bold" for="budget">Monthly Budget ($)</label>
            <input id="budget" name="budget" type="number" step="0.01" min="1" class="form-control shadow-sm" value="@Model.MonthlyBudget" />
        </div>
        <div class="col-auto">
            <button class="btn btn-primary shadow-sm" type="submit">Recalculate</button>
        </div>
    </form>

    @if (Model.Artists.Count == 0)
    {
        <div class="alert alert-info shadow-sm">
            <i class="fas fa-info-circle me-2"></i>No artist listening data found yet. Play and scrobble more tracks first.
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded-3 overflow-hidden border">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Artist</th>
                        <th class="text-center">Album Price</th>
                        <th class="text-center">Ethical Score</th>
                        <th class="text-end">Suggested Support</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var artist in Model.Artists)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">
                                @artist.ArtistName
                                @if (!string.IsNullOrEmpty(artist.SuggestedAlbumName))
                                {
                                    <div class="small text-muted fw-normal">
                                        <i class="fas fa-compact-disc me-1"></i>Rec: @artist.SuggestedAlbumName
                                    </div>
                                }
                            </td>
                            <td class="text-center">
                                @if (artist.SuggestedAlbumPrice.HasValue)
                                {
                                    <div class="fw-semibold">$@artist.SuggestedAlbumPrice.Value.ToString("0.00")</div>
                                }
                                else
                                {
                                    <span class="text-muted">Unavailable</span>
                                }
                            </td>
                            <td class="text-center font-monospace">@artist.EthicalScore.ToString("F4")</td>
                            <td class="text-end fw-bold text-success">$@artist.SuggestedBudget</td>
                            <td class="text-end pe-3">
                                <div class="d-flex justify-content-end gap-2">
                                    @if (artist.SuggestedAlbumId.HasValue)
                                    {
                                        <a asp-action="Purchase" asp-controller="Ethical" asp-route-artistId="@artist.ArtistId" asp-route-albumId="@artist.SuggestedAlbumId.Value" asp-route-budget="@Model.MonthlyBudget" class="btn btn-sm btn-warning shadow-sm px-3" title="Open purchase redirect">
                                            <i class="fab fa-amazon me-1"></i>Buy on Amazon
                                        </a>
                                    }
                                    <form method="post" asp-action="LogPurchase" asp-controller="Ethical" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="artistId" value="@artist.ArtistId" />
                                        <input type="hidden" name="budget" value="@Model.MonthlyBudget" />
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Log Purchase">
                                            <i class="fas fa-check"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

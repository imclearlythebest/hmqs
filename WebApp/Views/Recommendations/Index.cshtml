@{
  ViewData["Title"] = "Global Recommendations";
}

<div class="hmqs-panel p-3 p-lg-4">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h5 class="m-0">Global Recommendations</h5>
    <span class="small text-body-secondary">iTunes RSS feed via HTMX</span>
  </div>

  <div class="alert alert-secondary mb-3">
    Scroll down to load more. Up to 50 recommendations are available.
  </div>

  <div id="hmqs-recommendation-list"
       class="hmqs-recommendation-grid"
       hx-get="@Url.Action("Feed", "Recommendations", new { page = 1 })"
       hx-trigger="load"
       hx-swap="beforeend">
  </div>
</div>

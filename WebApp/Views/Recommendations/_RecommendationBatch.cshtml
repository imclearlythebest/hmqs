@model WebApp.Models.Dtos.RecommendationBatchDto

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
  <div class="alert alert-warning" role="alert">
    @Model.ErrorMessage
  </div>
}
else if (!string.IsNullOrWhiteSpace(Model.InfoMessage) && Model.Items.Count == 0)
{
  <div class="alert alert-secondary" role="alert">
    @Model.InfoMessage
  </div>
}
else
{
  foreach (var item in Model.Items)
  {
    var title = string.IsNullOrWhiteSpace(item.Title) ? "Unknown title" : item.Title;
    var artist = string.IsNullOrWhiteSpace(item.Artist) ? "Unknown artist" : item.Artist;
    var statusLabel = "Download";

    <article class="hmqs-recommendation-card" data-recommendation-card data-itunes-track-id="@item.ItunesTrackId">
      <div class="hmqs-recommendation-cover">
        @if (!string.IsNullOrWhiteSpace(item.ArtworkUrl))
        {
          <img src="@item.ArtworkUrl" alt="@($"{title} cover")" loading="lazy">
        }
        else
        {
          <div class="hmqs-cover-placeholder" aria-hidden="true">
            <i class="fa-solid fa-music"></i>
          </div>
        }
      </div>
      <div class="hmqs-recommendation-body">
        <h6 class="m-0 text-truncate" title="@title">@title</h6>
        <p class="text-body-secondary m-0 text-truncate" title="@artist">@artist</p>
        <button type="button"
                class="btn btn-sm mt-2 hmqs-rec-download-btn btn-primary"
                onclick="window.hmqsRecommendationDownload(this)"
                data-track-title="@title"
                data-artist-name="@artist"
                data-itunes-track-id="@item.ItunesTrackId"
                data-image-url="@item.ArtworkUrl"
                data-apple-music-url="@item.AppleMusicUrl"
                data-status-label="@statusLabel">
          <i class="fa-solid fa-download me-1"></i>
          <span class="hmqs-rec-download-label">@statusLabel</span>
        </button>
        <span class="badge bg-success-subtle text-success-emphasis mt-2 hmqs-rec-inlib-badge d-none">
          <i class="fa-solid fa-check me-1"></i>In library
        </span>
      </div>
    </article>
  }

  if (Model.NextPage.HasValue)
  {
    <div class="hmqs-rec-sentinel"
         hx-get="@Url.Action(Model.FeedAction, "Recommendations", new { page = Model.NextPage.Value })"
         hx-trigger="revealed"
         hx-swap="outerHTML">
      <div class="text-center text-body-secondary py-3">Loading more recommendations...</div>
    </div>
  }
  else if (Model.Items.Count > 0)
  {
    <div class="alert alert-light border text-center mt-3 mb-0">
      No more recommendations to load.
    </div>
  }
}

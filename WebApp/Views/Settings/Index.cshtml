@model WebApp.Models.WebAppUser
@{
    ViewData["Title"] = "Settings";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4">User Settings</h2>

            @if (TempData["SettingsMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SettingsMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["SettingsError"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["SettingsError"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card hmqs-card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">
                        <i class="fa-brands fa-discord me-2 text-primary"></i>Discord Integration
                    </h5>
                    <p class="text-body-secondary small mb-4">
                        Broadcasting your "Now Playing" activity to a Discord channel. To get started, create a Webhook in your Discord Server (Server Settings > Integrations > Webhooks) and paste the URL below.
                    </p>

                    <form asp-action="UpdateDiscord" method="post">
                        <div class="mb-3">
                            <label for="discordWebhookUrl" class="form-label">Webhook URL</label>
                            <input type="url" 
                                   class="form-control" 
                                   id="discordWebhookUrl" 
                                   name="discordWebhookUrl" 
                                   value="@Model.DiscordWebhookUrl" 
                                   placeholder="https://discord.com/api/webhooks/..." />
                        </div>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </form>
                </div>
            </div>

            <div class="card hmqs-card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Account Information</h5>
                    <div class="row mb-2">
                        <div class="col-sm-4 text-body-secondary">Username</div>
                        <div class="col-sm-8 fw-semibold">@Model.UserName</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 text-body-secondary">Email</div>
                        <div class="col-sm-8">@Model.Email</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

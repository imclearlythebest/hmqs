@model WebApp.Models.ViewModels.PlaylistShareViewModel
@{
    ViewData["Title"] = $"Playlist: {Model.Name}";
}

@section Styles {
    <style>
        .hmqs-share-page {
            min-height: 100vh;
            padding: 3rem 1.5rem;
            background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
            color: #ffffff;
            font-family: 'Inter', system-ui, sans-serif;
        }

        .playlist-header {
            max-width: 800px;
            margin: 0 auto 3rem;
            text-align: center;
            animation: fadeInDown 0.6s ease;
        }

        .playlist-title {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            background: linear-gradient(to right, #4facfe 0%, #00f2fe 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .playlist-meta {
            font-size: 1.2rem;
            color: rgba(255, 255, 255, 0.7);
        }

        .track-list {
            max-width: 800px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .track-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            transition: all 0.3s ease;
            animation: fadeInUp 0.5s ease forwards;
            opacity: 0;
            transform: translateY(20px);
        }

        .track-card:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-5px) scale(1.01);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .track-number {
            font-size: 1.5rem;
            font-weight: 700;
            color: rgba(255, 255, 255, 0.2);
            width: 40px;
            text-align: center;
        }

        .track-info {
            flex-grow: 1;
        }

        .track-name {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .track-artist {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.95rem;
        }

        .track-links {
            display: flex;
            gap: 0.5rem;
        }

        .btn-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .btn-icon-spotify { background: #1DB954; }
        .btn-icon-spotify:hover { background: #1ed760; transform: scale(1.1); box-shadow: 0 5px 15px rgba(29, 185, 84, 0.4); color: white;}
        
        .btn-icon-apple { background: #fa243c; }
        .btn-icon-apple:hover { background: #ff334b; transform: scale(1.1); box-shadow: 0 5px 15px rgba(250, 36, 60, 0.4); color: white;}
        
        .btn-icon-youtube { background: #FF0000; }
        .btn-icon-youtube:hover { background: #ff1a1a; transform: scale(1.1); box-shadow: 0 5px 15px rgba(255, 0, 0, 0.4); color: white;}

        @@keyframes fadeInUp {
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        @@keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .no-links-mini {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.4);
            font-style: italic;
        }
    </style>
}

<div class="hmqs-share-page">
    <div class="playlist-header">
        <h1 class="playlist-title">@Model.Name</h1>
        <div class="playlist-meta">Shared Playlist • @Model.Tracks.Count tracks</div>
    </div>

    <div class="track-list">
        @for (int i = 0; i < Model.Tracks.Count; i++)
        {
            var track = Model.Tracks[i];
            <div class="track-card" style="animation-delay: @(i * 0.1)s">
                <div class="track-number">@(i + 1)</div>
                
                @if (!string.IsNullOrEmpty(track.ImageUrl))
                {
                    <img src="@track.ImageUrl" alt="Cover" style="width: 60px; height: 60px; border-radius: 8px; object-fit: cover;" />
                }
                else
                {
                    <div style="width: 60px; height: 60px; border-radius: 8px; background: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center;">
                        <i class="fa-solid fa-music" style="color: rgba(255,255,255,0.5)"></i>
                    </div>
                }

                <div class="track-info">
                    <div class="track-name">@track.Title</div>
                    <div class="track-artist">@track.Artist @(!string.IsNullOrEmpty(track.Album) ? $" • {track.Album}" : "")</div>
                </div>

                <div class="track-links">
                    @if (track.PlatformUrls.Any())
                    {
                        @if (track.PlatformUrls.TryGetValue("spotify", out var sUrl))
                        {
                            <a href="@sUrl" target="_blank" class="btn-icon btn-icon-spotify" title="Spotify"><i class="fa-brands fa-spotify"></i></a>
                        }
                        @if (track.PlatformUrls.TryGetValue("appleMusic", out var aUrl))
                        {
                            <a href="@aUrl" target="_blank" class="btn-icon btn-icon-apple" title="Apple Music"><i class="fa-brands fa-apple"></i></a>
                        }
                        @if (track.PlatformUrls.TryGetValue("youtube", out var yUrl))
                        {
                            <a href="@yUrl" target="_blank" class="btn-icon btn-icon-youtube" title="YouTube"><i class="fa-brands fa-youtube"></i></a>
                        }
                    }
                    else
                    {
                        <span class="no-links-mini">No links</span>
                    }
                </div>
            </div>
        }
        
        @if (Model.Tracks.Count == 0)
        {
            <div class="text-center text-white-50 mt-5">This playlist is empty.</div>
        }
    </div>
</div>

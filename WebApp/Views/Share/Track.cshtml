@model ShareViewModel
@{
    ViewData["Title"] = $"Share — {Model.TrackName}";
    var shareUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/Share/Track/{Model.TrackId}";
}

@section Styles {
<style>
  .share-card {
    max-width: 560px;
    margin: 3rem auto;
    border-radius: 1.25rem;
    overflow: hidden;
  }
  .share-artwork {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    max-height: 280px;
  }
  .share-artwork-placeholder {
    width: 100%;
    max-height: 280px;
    aspect-ratio: 1;
    background: linear-gradient(135deg, var(--bs-primary), var(--bs-info));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    color: rgba(255,255,255,.6);
  }
  .platform-btn {
    display: flex;
    align-items: center;
    gap: .5rem;
    border-radius: .6rem;
    font-weight: 500;
    font-size: .9rem;
    transition: transform .15s, box-shadow .15s;
  }
  .platform-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(0,0,0,.15); }
  .platform-btn img { width: 22px; height: 22px; border-radius: 4px; }
  .copy-link-btn { font-size: .8rem; }
</style>
}

<div class="share-card hmqs-panel shadow-lg">
  @if (!string.IsNullOrWhiteSpace(Model.ArtworkUrl))
  {
    <img src="@Model.ArtworkUrl" alt="Artwork for @Model.TrackName" class="share-artwork" />
  }
  else
  {
    <div class="share-artwork-placeholder">
      <i class="fa-solid fa-music"></i>
    </div>
  }

  <div class="p-4">
    <h4 class="fw-bold mb-1">@Model.TrackName</h4>
    <p class="text-body-secondary mb-0">@Model.ArtistName</p>
    @if (Model.Year > 0)
    {
      <p class="text-body-secondary small mb-0">@Model.Year &bull; @Model.GenreName</p>
    }

    <hr class="my-3" />

    @if (Model.SpotifyUrl != null || Model.AppleMusicUrl != null || Model.YoutubeUrl != null || Model.YoutubeMusicUrl != null)
    {
      <p class="small text-body-secondary mb-3">Listen on your preferred platform:</p>
      <div class="d-flex flex-column gap-2 mb-4">
        @if (Model.SpotifyUrl != null)
        {
          <a href="@Model.SpotifyUrl" target="_blank" rel="noopener" class="btn btn-success platform-btn">
            <i class="fa-brands fa-spotify"></i> Open in Spotify
          </a>
        }
        @if (Model.AppleMusicUrl != null)
        {
          <a href="@Model.AppleMusicUrl" target="_blank" rel="noopener" class="btn btn-danger platform-btn">
            <i class="fa-brands fa-apple"></i> Open in Apple Music
          </a>
        }
        @if (Model.YoutubeMusicUrl != null)
        {
          <a href="@Model.YoutubeMusicUrl" target="_blank" rel="noopener" class="btn btn-danger platform-btn" style="background:#ff0000;border-color:#ff0000;">
            <i class="fa-brands fa-youtube"></i> Open in YouTube Music
          </a>
        }
        @if (Model.YoutubeUrl != null)
        {
          <a href="@Model.YoutubeUrl" target="_blank" rel="noopener" class="btn btn-outline-danger platform-btn">
            <i class="fa-brands fa-youtube"></i> Watch on YouTube
          </a>
        }
      </div>
    }
    else
    {
      <p class="small text-body-secondary mb-4">
        <i class="fa-solid fa-circle-info me-1"></i>No streaming links found for this track yet.
      </p>
    }

    <div class="d-flex align-items-center gap-2">
      <input id="shareLinkInput" type="text" class="form-control form-control-sm" value="@shareUrl" readonly />
      <button id="copyShareLink" class="btn btn-sm btn-outline-secondary copy-link-btn text-nowrap" onclick="copyShareLink()">
        <i class="fa-solid fa-copy me-1"></i>Copy Link
      </button>
    </div>
  </div>
</div>

@section Scripts {
<script>
  function copyShareLink() {
    const input = document.getElementById('shareLinkInput');
    navigator.clipboard.writeText(input.value).then(() => {
      const btn = document.getElementById('copyShareLink');
      btn.innerHTML = '<i class="fa-solid fa-check me-1"></i>Copied!';
      btn.classList.replace('btn-outline-secondary', 'btn-success');
      setTimeout(() => {
        btn.innerHTML = '<i class="fa-solid fa-copy me-1"></i>Copy Link';
        btn.classList.replace('btn-success', 'btn-outline-secondary');
      }, 2000);
    });
  }
</script>
}

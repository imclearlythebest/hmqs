<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/svg+xml" href="/images/favicon/music-solid-full.svg">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css" asp-append-version="true">
    @RenderSection("Styles", required: false)
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js" integrity="sha384-/TgkGk7p307TH7EXJDuUlgG3Ce1UVolAOFopFekQkkXihi5u/6OCvVKyz1W+idaz" crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/idb@8/build/umd.js"></script>
    <script src="/js/client/db.js" asp-append-version="true"></script>
    <script src="/js/client/picker.js" asp-append-version="true"></script>
    <script src="/js/client/metadata.js" asp-append-version="true"></script>
    <script src="/js/client/player.js" asp-append-version="true"></script>
    <script src="/js/client/playlist.js" asp-append-version="true"></script>
    <script src="/js/client/downloader.js" asp-append-version="true"></script>
    <script src="/js/client/index.js" asp-append-version="true"></script>
    <script src="/js/client/pages.js" asp-append-version="true"></script>
    <title>@ViewData["Title"] - HMQS</title>
  </head>

  <body class="hmqs-body bg-body" data-is-authenticated="@((User.Identity?.IsAuthenticated == true).ToString().ToLowerInvariant())">
    <header class="border-bottom bg-body-tertiary">
      <partial name="_Navbar" />
    </header>

    <div class="container-fluid hmqs-shell">
      <div class="hmqs-workspace @(ViewData["HideSidebar"] as bool? == true ? "hmqs-workspace-full" : "")">
        @if (ViewData["HideSidebar"] as bool? != true)
        {
          <aside class="border-end d-none d-lg-flex p-3 bg-body-tertiary hmqs-sidebar">
            <partial name="_Sidebar" />
          </aside>
        }
        <main class="hmqs-main">
          <div class="p-3 hmqs-content">
            @RenderBody()
          </div>
        </main>
      </div>
    </div>

    @if (ViewData["HidePlayer"] as bool? != true)
    {
      <footer class="hmqs-player-bar border-top p-2">
        <partial name="_Player" />
      </footer>
    }
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="/js/script.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
  </body>

</html>